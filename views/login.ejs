<%- include('partials/header', { pageTitle, currentUserId }) %>

<section class="auth-card">
  <h1>Login</h1>
  <p class="page-note">Sign in to view your boards and manage tasks.</p>

  <% if (error) { %>
    <div class="message error"><%= error %></div>
  <% } %>

  <form action="/dashboard" method="GET" class="stack-form">
    <label>
      Email
      <input type="email" name="email" required />
    </label>

    <label>
      Password
      <input type="password" name="password" required />
    </label>

    <button type="submit">Login</button>
  </form>

  <p class="page-note">
    New here?
    <a href="/signup">Create an account</a>
  </p>
</section>

<%- include('partials/footer') %>
